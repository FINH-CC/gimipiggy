               U_SWITCH_COM --- * P35        P21 *
              ADAFRUIT_BCLK --- * P32        GND * --- SYSTEM_GND
                ADAFRUIT_LR --- * P33        P19 * --- CREE_RED_NEG
               ADAFRUIT_DAT --- * P25        P18 * --- CREE_GREEN_NEG
               ADAFRUIT_SEL --- * P26         P5 * --- CREE_BLUE_NEG
               ADAFRUIT_SCK --- * P27        P17 *
                ADAFRUIT_MI --- * P14        P16 *
                ADAFRUIT_MO --- * P12         P4 *
                 SYSTEM_GND --- * GND         P0 *
                                * P13         P2 *
                                * SD2        P15 *
                                * SD3        SD1 *
                                * CND        SD0 *
                 SYSTEM_9V0 --- * 5V         CLK *
                                ******************

